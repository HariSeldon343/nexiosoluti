APP_NAME=NexioSolution
APP_ENV=local
APP_KEY=base64:YourRandomGeneratedKeyWillBeHere32Char=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration per XAMPP
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexiosolution
DB_USERNAME=root
DB_PASSWORD=

# Driver per ambiente XAMPP
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Memcached (opzionale)
MEMCACHED_HOST=127.0.0.1

# Redis (opzionale se installato)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration per XAMPP
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@nexiosolution.local"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (opzionale per S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher/WebSockets Configuration
PUSHER_APP_ID=nexiosolution
PUSHER_APP_KEY=nexiosolutionkey
PUSHER_APP_SECRET=nexiosolutionsecret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# Laravel WebSockets
LARAVEL_WEBSOCKETS_SSL_LOCAL_CERT=null
LARAVEL_WEBSOCKETS_SSL_LOCAL_PK=null
LARAVEL_WEBSOCKETS_SSL_PASSPHRASE=null

# JWT Authentication
JWT_SECRET=YourJWTSecretKeyWillBeGeneratedHere
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

# Google 2FA
GOOGLE_2FA_ENABLED=true

# Multi-tenant Configuration
TENANT_IDENTIFICATION=header
TENANT_IDENTIFICATION_METHOD=subdomain
TENANT_DEFAULT_DOMAIN=localhost
TENANT_DEFAULT_SUBDOMAIN=app
DEFAULT_TENANT=demo

# CalDAV Configuration
CALDAV_ENABLED=true
CALDAV_BASE_URI=/caldav
CALDAV_AUTH_BACKEND=laravel

# File Storage Configuration
FILE_STORAGE_PATH=storage/app/tenants
FILE_MAX_SIZE=10485760
FILE_ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,jpg,jpeg,png,gif,zip

# Document Server (opzionale)
DOCUMENT_SERVER_ENABLED=false
DOCUMENT_SERVER_URL=
DOCUMENT_SERVER_SECRET=

# Jitsi Meet Integration
JITSI_ENABLED=true
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=nexiosolution

# Web Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nexiosolution.local

# Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=1

# Audit Log
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# Telescope (debug in sviluppo)
TELESCOPE_ENABLED=false

# Horizon (job queue dashboard)
HORIZON_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_DESTINATION=local
BACKUP_RETENTION_DAYS=30