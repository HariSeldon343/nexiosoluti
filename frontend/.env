# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_BASE_PATH=/api

# WebSocket Configuration
VITE_WS_URL=ws://localhost:6001
VITE_WS_APP_KEY=local

# Application Settings
VITE_APP_NAME=NexioSolution
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Auth Settings
VITE_AUTH_TOKEN_KEY=nexio_auth_token
VITE_AUTH_REFRESH_KEY=nexio_refresh_token

# PWA Settings
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true

# Feature Flags
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_DARK_MODE=true

# Upload Settings
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.svg,.zip

# Debug
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug